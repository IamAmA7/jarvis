# ──────────────────────────────────────────────────────────────────────────
# Jarvis — environment variables
# ──────────────────────────────────────────────────────────────────────────
#
# Copy this file to `.env.local` for local development. For production,
# set these in Vercel → Settings → Environment Variables.
#
# Secrets (OpenAI, Anthropic, Deepgram, Stripe, Supabase service role) live
# ONLY on the server and must NEVER be exposed with a VITE_ prefix — the
# browser never sees them. Clerk publishable key and Supabase URL/anon key
# are safe to ship.

# ─── Frontend (browser, VITE_ prefix) ─────────────────────────────────────

# Clerk — public publishable key from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx

# Supabase — public anon key + project URL (read-only, RLS-protected)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# PostHog — product analytics (optional, omit to disable)
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry — browser error tracking (optional, omit to disable)
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── Server (Vercel Functions, no VITE_ prefix) ───────────────────────────

# Transcription providers
OPENAI_API_KEY=sk-proj-...
DEEPGRAM_API_KEY=...
DEEPGRAM_PROJECT_ID=...

# Claude
ANTHROPIC_API_KEY=sk-ant-...

# Clerk — used server-side to verify JWTs via JWKS
CLERK_SECRET_KEY=sk_test_...
# REQUIRED in production. Pin the expected JWT issuer — e.g.
#   https://your-app.clerk.accounts.dev    (dev)
#   https://clerk.your-domain.com          (prod with custom domain)
# Find it in Clerk Dashboard → API Keys → "Issuer URL". Without this set,
# /api/* returns 500 for every request, by design — trusting the token's own
# `iss` claim is a forgery vector.
CLERK_JWT_ISSUER=

# Supabase — service role has full access; used only by /api/* functions
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_xxxxxxxxxxxxxxxxxxxx

# Where Stripe Checkout should send the user back to
APP_URL=https://jarvis.example.com

# Sentry — server error tracking (optional)
SENTRY_DSN_SERVER=

# ─── Listener mode (wearable device + Telegram alerts) ────────────────────

# Telegram bot you create via @BotFather. Token format: "123456:ABC-DEF...".
# Used for (a) red alert pushes from /api/ingest, (b) daily yellow digest.
TELEGRAM_BOT_TOKEN=
# Bot's public @username (without @). Used to build t.me deep links on the
# dashboard when users link their chat.
TELEGRAM_BOT_USERNAME=
# Shared secret you set when calling Telegram's setWebhook. We verify it on
# every incoming /api/telegram/webhook call. Generate with `openssl rand -hex 32`.
TELEGRAM_WEBHOOK_SECRET=

# Vercel cron invocations send Authorization: Bearer <CRON_SECRET>. Any
# random string works; set it in Vercel env too. Leave empty to fall back
# to Vercel's built-in `x-vercel-cron: 1` header check (slightly weaker).
CRON_SECRET=
