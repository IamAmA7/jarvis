{
  "name": "jarvis",
  "version": "0.4.0",
  "private": true,
  "description": "Jarvis — AI voice intelligence. Whisper/Deepgram transcription + Claude insights, Clerk-authenticated, server-side API keys, WebHID push-to-talk.",
